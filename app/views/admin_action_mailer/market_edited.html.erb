<h1><%= t("admin_action_mailer.market_edited.heading") %></h1>

<p><%= t("admin_action_mailer.market_edited.body", actor: @actor_name, title: @market.title, group: @market.group.name) %></p>

<ul>
  <% @changes.each do |field, (before, after)| %>
    <li><%= t("admin_action_mailer.market_edited.fields.#{field}") %>: <%= change_value(before) %> → <%= change_value(after) %></li>
  <% end %>
</ul>

<p>
  <a href="<%= @link %>" style="display:inline-block;padding:10px 20px;background:#0066cc;color:#fff;text-decoration:none;border-radius:4px;"><%= t("admin_action_mailer.shared.view_button") %></a>
</p>

<p><%= @link %></p>

<p><%= t("admin_action_mailer.shared.mandatory") %></p>
